<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Full-screen intent for background broadcasts (incoming call style) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    
    <!-- Camera permission for profile photo capture -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    
    <!-- SMS Auto-Read for OTP uses Google SMS Retriever API -->
    <!-- ZERO permissions needed — SMS Retriever works without RECEIVE_SMS/READ_SMS -->
    <!-- Removing dangerous permissions improves Play Store approval -->

    <!-- Telephony feature declaration (not required, supports non-phone devices) -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <application
        android:name=".WeeloApp"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WeeloLogistics"
        tools:targetApi="31">
        
        <!-- Main Activity - LAUNCHER -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.WeeloLogistics"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Broadcast Incoming Activity - Full-screen intent for background broadcasts -->
        <!-- Shows broadcast offer on lock screen, like an incoming phone call -->
        <!--
            F-C-04 — Dual-theme rollout via activity-alias.
            - The base <activity> owns the concrete class and default opaque
              theme (legacy path). It is enabled while
              FF_BROADCAST_TRANSLUCENT_THEME is OFF.
            - The <activity-alias> below points at the same class but applies
              the translucent overlay theme; it is enabled only when the flag
              flips ON (manifest placeholder fed from build.gradle.kts).
            Exactly one of the two is enabled at any given time — callers
            start the alias name when the flag is ON, and the concrete class
            name when OFF. The BroadcastFullScreenNotifier chooses at runtime.
        -->
        <activity
            android:name=".broadcast.BroadcastIncomingActivity"
            android:exported="false"
            android:enabled="${broadcastLegacyThemeEnabled}"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.WeeloLogistics"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:launchMode="singleInstance" />

        <!-- F-C-04 — Translucent-theme alias (FF_BROADCAST_TRANSLUCENT_THEME ON). -->
        <activity-alias
            android:name=".broadcast.BroadcastIncomingActivityOverlay"
            android:enabled="${broadcastOverlayThemeEnabled}"
            android:exported="false"
            android:targetActivity=".broadcast.BroadcastIncomingActivity"
            android:theme="@style/Theme.WeeloLogistics.BroadcastOverlay" />
        
        <!-- GPS Tracking Service - Real-time location for trips -->
        <service
            android:name=".utils.GPSTrackingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location"
            android:permission="android.permission.FOREGROUND_SERVICE_LOCATION" />

        <!-- Transporter Online Service - keeps heartbeat active when app is closed -->
        <service
            android:name=".utils.TransporterOnlineService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location"
            android:permission="android.permission.FOREGROUND_SERVICE_LOCATION" />
        
        <!-- Firebase Cloud Messaging Service -->
        <service
            android:name=".data.remote.WeeloFirebaseService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        
        <!-- FCM default notification channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="broadcasts" />
        
        <!-- ================================================================== -->
        <!-- GOOGLE MAPS API KEY                                                -->
        <!-- Required for: Maps SDK, Geocoding API, Places API                  -->
        <!-- Used by: Driver location tracking, route display, address search   -->
        <!-- ================================================================== -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />
            
    </application>

</manifest>
